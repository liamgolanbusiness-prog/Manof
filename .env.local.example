NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key>
SUPABASE_SERVICE_ROLE_KEY=<service role key>
NEXT_PUBLIC_APP_NAME=Atar
NEXT_PUBLIC_APP_URL=http://localhost:4000

# Optional telemetry — app works fine without these.
# Sentry: paste your project DSN (browser). Leave blank to disable.
NEXT_PUBLIC_SENTRY_DSN=
# PostHog: leave blank to disable; host defaults to app.posthog.com.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# AI features — receipt OCR (Claude Vision) + voice transcription (Whisper).
# App works without these; features degrade to manual entry.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Outbound messaging. Both NOOP when unset; wa.me deep links remain as fallback.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
